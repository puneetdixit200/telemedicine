generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  patient
  doctor
  admin
  help_worker
}

enum SlotStatus {
  available
  busy
  booked
}

enum AppointmentStatus {
  booked
  completed
  cancelled
  no_show
}

enum TriageLevel {
  unknown
  low
  moderate
  high
  critical
}

enum ConsultationMode {
  video
  audio
  text
}

enum CallSessionStatus {
  ready
  in_progress
  ended
  failed
}

enum ReminderChannel {
  sms
  whatsapp
}

enum ReminderStatus {
  scheduled
  sent
  failed
  skipped
}

enum DelegationScope {
  appointment
  async_consult
  records
  all
}

enum AsyncConsultStatus {
  open
  waiting_doctor
  waiting_patient
  closed
}

enum AsyncAuthorRole {
  patient
  doctor
  helper
  system
}

model User {
  id             String   @id @default(uuid())
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  email          String   @unique
  phone          String?
  fullName       String
  passwordHash   String
  role           Role
  isActive       Boolean  @default(true)
  lastSeenAt     DateTime?

  gender         String?
  dateOfBirth    DateTime?
  address        String?
  language       String?
  timeZone       String?

  patientProfile PatientProfile?
  doctorProfile  DoctorProfile?
  familyMembers  FamilyMember[]

  asPatientAppointments Appointment[] @relation("appointments_as_patient")
  asDoctorAppointments  Appointment[] @relation("appointments_as_doctor")

  slots          Slot[] @relation("doctor_slots")

  documents      Document[]

  doctorReviewsReceived DoctorReview[] @relation("doctor_reviews_received")
  doctorReviewsWritten  DoctorReview[] @relation("doctor_reviews_written")

  reminderJobs          ReminderJob[]     @relation("patient_reminders")
  careSupportLinks      CareSupportLink[] @relation("care_support_patient")
  createdSupportLinks   CareSupportLink[] @relation("care_support_creator")
  consentAuditAsPatient ConsentAudit[]    @relation("consent_patient")
  consentAuditActions   ConsentAudit[]    @relation("consent_granted_by")

  patientAsyncConsults  AsyncConsult[]    @relation("async_consults_patient")
  doctorAsyncConsults   AsyncConsult[]    @relation("async_consults_doctor")
  asyncRepliesAuthored  AsyncConsultReply[] @relation("async_reply_author")
}

model PatientProfile {
  userId            String  @id
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  chronicConditions String?
  basicHealthInfo   String?
}

model DoctorProfile {
  userId               String  @id
  user                 User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  specialization       String
  yearsOfExperience    Int?
  qualifications       String?
  clinicName           String?
  consultationLanguages String?
  description          String?
  callEnabled          Boolean @default(false)
}

model Slot {
  id        String     @id @default(uuid())
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  doctorId  String
  doctor    User       @relation("doctor_slots", fields: [doctorId], references: [id], onDelete: Cascade)

  startAt   DateTime
  status    SlotStatus @default(available)

  appointment Appointment?

  @@unique([doctorId, startAt])
  @@index([doctorId, startAt])
}

model Appointment {
  id          String            @id @default(uuid())
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  patientId   String
  doctorId    String
  familyMemberId String?
  patient     User              @relation("appointments_as_patient", fields: [patientId], references: [id], onDelete: Cascade)
  doctor      User              @relation("appointments_as_doctor", fields: [doctorId], references: [id], onDelete: Cascade)
  familyMember FamilyMember?    @relation(fields: [familyMemberId], references: [id], onDelete: SetNull)

  startAt     DateTime
  status      AppointmentStatus @default(booked)
  mode        ConsultationMode  @default(video)

  problemDescription String?
  medicationsText    String?
  triageLevel        TriageLevel       @default(unknown)
  triageScore        Int               @default(0)

  slotId      String?  @unique
  slot        Slot?    @relation(fields: [slotId], references: [id], onDelete: SetNull)

  callSession CallSession?
  prescription Prescription?
  documents   Document[]
  review      DoctorReview?
  reminderJobs ReminderJob[]
  consentAudits ConsentAudit[]
  asyncConsults AsyncConsult[]

  @@index([doctorId, startAt])
  @@index([patientId, startAt])
  @@index([familyMemberId])
  @@index([triageLevel])
}

model FamilyMember {
  id                String   @id @default(uuid())
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  ownerPatientId    String
  ownerPatient      User     @relation(fields: [ownerPatientId], references: [id], onDelete: Cascade)

  fullName          String
  relationToPatient String?
  gender            String?
  dateOfBirth       DateTime?
  chronicConditions String?
  basicHealthInfo   String?

  appointments      Appointment[]
  documents         Document[]
  asyncConsults     AsyncConsult[]

  @@index([ownerPatientId, fullName])
}

model CallSession {
  id            String            @id @default(uuid())
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  appointmentId String            @unique
  appointment   Appointment       @relation(fields: [appointmentId], references: [id], onDelete: Cascade)

  status        CallSessionStatus @default(ready)
  startedAt     DateTime?
  endedAt       DateTime?
}

model Document {
  id            String   @id @default(uuid())
  createdAt     DateTime @default(now())

  ownerId       String
  owner         User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  familyMemberId String?
  familyMember   FamilyMember? @relation(fields: [familyMemberId], references: [id], onDelete: SetNull)

  appointmentId String?
  appointment   Appointment? @relation(fields: [appointmentId], references: [id], onDelete: SetNull)

  fileName      String
  contentType   String
  sizeBytes     Int

  blobName      String

  @@index([ownerId, appointmentId, familyMemberId])
}

model Prescription {
  id            String   @id @default(uuid())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  appointmentId String   @unique
  appointment   Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)

  diagnosis     String
  items         Json
  instructions  String?
  followUpAt    DateTime?
  notes         String?
  pharmacyName  String?
  pharmacyContact String?
  handoffCode   String?

  @@index([handoffCode])
}

model DoctorReview {
  id            String   @id @default(uuid())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  appointmentId String   @unique
  appointment   Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)

  doctorId      String
  doctor        User     @relation("doctor_reviews_received", fields: [doctorId], references: [id], onDelete: Cascade)

  patientId     String
  patient       User     @relation("doctor_reviews_written", fields: [patientId], references: [id], onDelete: Cascade)

  rating        Int
  comment       String?

  @@index([doctorId, createdAt])
  @@index([patientId, createdAt])
}

model ReminderJob {
  id            String          @id @default(uuid())
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  appointmentId String
  appointment   Appointment     @relation(fields: [appointmentId], references: [id], onDelete: Cascade)

  patientId     String
  patient       User            @relation("patient_reminders", fields: [patientId], references: [id], onDelete: Cascade)

  channel       ReminderChannel @default(sms)
  sendAt        DateTime
  templateKey   String
  payload       Json?
  status        ReminderStatus  @default(scheduled)
  attempts      Int             @default(0)
  sentAt        DateTime?
  failedAt      DateTime?
  lastError     String?

  @@index([status, sendAt])
  @@index([patientId, sendAt])
  @@index([appointmentId, sendAt])
}

model CareSupportLink {
  id                String   @id @default(uuid())
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  patientId         String
  patient           User     @relation("care_support_patient", fields: [patientId], references: [id], onDelete: Cascade)

  createdById       String
  createdBy         User     @relation("care_support_creator", fields: [createdById], references: [id], onDelete: Cascade)

  helperName        String
  helperPhone       String
  relationToPatient String?
  village           String?
  notes             String?
  isActive          Boolean  @default(true)

  consentAudits     ConsentAudit[]

  @@index([patientId, helperName])
  @@index([patientId, isActive])
}

model ConsentAudit {
  id            String          @id @default(uuid())
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  patientId     String
  patient       User            @relation("consent_patient", fields: [patientId], references: [id], onDelete: Cascade)

  helperId      String?
  helper        CareSupportLink? @relation(fields: [helperId], references: [id], onDelete: SetNull)

  appointmentId String?
  appointment   Appointment?    @relation(fields: [appointmentId], references: [id], onDelete: SetNull)

  scope         DelegationScope @default(appointment)
  action        String
  notes         String?
  isActive      Boolean         @default(true)
  revokedAt     DateTime?

  grantedById   String
  grantedBy     User            @relation("consent_granted_by", fields: [grantedById], references: [id], onDelete: Cascade)

  @@index([patientId, createdAt])
  @@index([appointmentId])
  @@index([isActive, scope])
}

model AsyncConsult {
  id              String            @id @default(uuid())
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  patientId       String
  patient         User              @relation("async_consults_patient", fields: [patientId], references: [id], onDelete: Cascade)

  doctorId        String
  doctor          User              @relation("async_consults_doctor", fields: [doctorId], references: [id], onDelete: Cascade)

  familyMemberId  String?
  familyMember    FamilyMember?     @relation(fields: [familyMemberId], references: [id], onDelete: SetNull)

  appointmentId   String?
  appointment     Appointment?      @relation(fields: [appointmentId], references: [id], onDelete: SetNull)

  status          AsyncConsultStatus @default(open)
  subject         String
  symptoms        String
  preferredLanguage String?
  priority        String?
  latestMessageAt DateTime          @default(now())

  replies         AsyncConsultReply[]

  @@index([doctorId, status, latestMessageAt])
  @@index([patientId, status, latestMessageAt])
}

model AsyncConsultReply {
  id            String         @id @default(uuid())
  createdAt     DateTime       @default(now())

  consultId     String
  consult       AsyncConsult   @relation(fields: [consultId], references: [id], onDelete: Cascade)

  authorRole    AsyncAuthorRole
  authorId      String?
  author        User?          @relation("async_reply_author", fields: [authorId], references: [id], onDelete: SetNull)
  authorName    String?
  message       String

  @@index([consultId, createdAt])
  @@index([authorId, createdAt])
}

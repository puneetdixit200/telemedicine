<%- include('partials/layout', { title: 'Appointments', user, body: `
<div class='card'>
  <div class='hero-header'>
    <h2 class='page-title' style='font-size:1.6rem;'>Upcoming Appointments</h2>
    <span class='badge'>${upcomingAppointments.length} total</span>
  </div>
  ${upcomingAppointments.length === 0 ? '<p>No upcoming appointments.</p>' : ''}

  ${upcomingAppointments.map(a => `
    <div class='card' style='margin-bottom:10px;'>
      <div class='row' style='align-items:center;'>
        <div>
          <div style='font-size:1.02rem; font-weight:700;'>${new Date(a.startAt).toISOString().replace('T',' ').slice(0,16)} UTC</div>
          <div style='margin-top:5px;'><span class='badge'>${a.status}</span> <span class='badge'>${a.mode}</span></div>
          <div style='margin-top:7px;'>
            ${user.role === 'doctor' ? `Patient: ${a.patient.fullName}` : `Doctor: ${a.doctor.fullName}`}
          </div>
          <div style='margin-top:5px;'>
            <span class='badge'>For: ${a.familyMember ? a.familyMember.fullName : a.patient.fullName}</span>
          </div>
        </div>
        <div style='align-self:center;'>
          <a class='btn-secondary' href='/appointments/${a.id}'>Open details</a>
        </div>
      </div>
    </div>
  `).join('')}
</div>

<div class='card'>
  <div class='hero-header'>
    <h2 class='page-title' style='font-size:1.6rem;'>Done Appointments</h2>
    <span class='badge'>${doneAppointments.length} total</span>
  </div>
  ${doneAppointments.length === 0 ? '<p>No completed/cancelled appointments yet.</p>' : ''}

  ${doneAppointments.map(a => `
    <div class='card' style='margin-bottom:10px;'>
      <div class='row' style='align-items:center;'>
        <div>
          <div style='font-size:1.02rem; font-weight:700;'>${new Date(a.startAt).toISOString().replace('T',' ').slice(0,16)} UTC</div>
          <div style='margin-top:5px;'><span class='badge'>${a.status}</span> <span class='badge'>${a.mode}</span></div>
          <div style='margin-top:7px;'>
            ${user.role === 'doctor' ? `Patient: ${a.patient.fullName}` : `Doctor: ${a.doctor.fullName}`}
          </div>
          <div style='margin-top:5px;'>
            <span class='badge'>For: ${a.familyMember ? a.familyMember.fullName : a.patient.fullName}</span>
          </div>
        </div>
        <div style='align-self:center;'>
          <a class='btn-secondary' href='/appointments/${a.id}'>Open details</a>
        </div>
      </div>
    </div>
  `).join('')}
</div>
` }) %>

<%- include('partials/layout', { title: 'Login', user, body: `
<div class='auth-shell'>
  <div class='card auth-card'>
    <p class='page-subtitle' style='text-transform:uppercase; letter-spacing:0.08em; margin:0 0 6px;'>Secure Portal</p>
    <h2 class='page-title'>Login</h2>
    ${error ? `<p class='error'>${error}</p>` : ''}
    <form method='post' action='/auth/login' style='margin-top:12px;'>
      <div class='row'>
        <div>
          <label>Email</label>
          <input name='email' type='email' required />
        </div>
        <div>
          <label>Password</label>
          <input name='password' type='password' required />
        </div>
      </div>
      <div style='margin-top:12px;'>
        <button type='submit'>Login</button>
      </div>
    </form>
    <p class='page-subtitle' style='margin-top:12px;'>No account? <a href='/auth/register'>Register</a></p>
  </div>

  <div class='card auth-card'>
    <h3 style='margin:0;'>Role Guide</h3>
    <p class='page-subtitle'>Use your registered credentials. Role is identified after login and the app theme updates by role.</p>
    <div class='role-login-grid'>
      <div class='role-login patient'>
        <div class='role-title'>Patient Login</div>
        <div class='role-desc'>Book appointments, upload reports, manage family health records, and view prescriptions.</div>
      </div>
      <div class='role-login doctor'>
        <div class='role-title'>Doctor Login</div>
        <div class='role-desc'>Manage slots, join consultations, review patient history, and issue prescriptions.</div>
      </div>
      <div class='role-login'>
        <div class='role-title'>Admin Login</div>
        <div class='role-desc'>Administrative oversight and access to all records based on system policy.</div>
      </div>
    </div>
  </div>
</div>
` }) %>

<%- include('partials/layout', { title: 'Login', user, body: `

<style>
.auth-shell {
  display: flex;
  gap: 24px;
  flex-wrap: wrap;
  justify-content: center;
}

.auth-card {
  flex: 1 1 380px;
  max-width: 420px;
}

/* Card */
.card {
  background: #ffffff;
  border-radius: 18px;
  padding: 24px;
  box-shadow: 0 10px 30px rgba(0,0,0,0.08);
  border: 1px solid #f1f1f1;
}

/* Titles */
.page-title {
  font-size: 1.8rem;
  margin: 0;
  font-weight: 600;
}

.page-subtitle {
  color: #6b7280;
  font-size: 0.9rem;
}

/* Inputs */
label {
  font-size: 12px;
  color: #6b7280;
  display: block;
  margin-bottom: 4px;
}

input {
  width: 100%;
  padding: 10px;
  border-radius: 10px;
  border: 1px solid #ddd;
  transition: 0.2s;
}
input:focus {
  border-color: #4f46e5;
  outline: none;
  box-shadow: 0 0 0 2px #eef2ff;
}

/* Layout */
.row {
  display: flex;
  gap: 12px;
  flex-wrap: wrap;
}
.row > div {
  flex: 1;
}

/* Button */
button {
  width: 100%;
  background: linear-gradient(135deg, #4f46e5, #6366f1);
  color: white;
  padding: 12px;
  border-radius: 10px;
  border: none;
  font-weight: 500;
  cursor: pointer;
  transition: 0.25s;
}
button:hover {
  transform: translateY(-1px);
  box-shadow: 0 6px 18px rgba(79,70,229,0.3);
}

/* Error */
.error {
  color: #dc2626;
  font-size: 0.9rem;
}

/* Roles */
.role-login-grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: 12px;
  margin-top: 12px;
}

.role-login {
  padding: 14px;
  border-radius: 12px;
  background: #f9fafb;
  border: 1px solid #eee;
}

.role-login.patient {
  background: #ecfeff;
  border-color: #67e8f9;
}

.role-login.doctor {
  background: #eef2ff;
  border-color: #c7d2fe;
}

.role-title {
  font-weight: 600;
  margin-bottom: 4px;
}

.role-desc {
  font-size: 0.85rem;
  color: #6b7280;
}

/* Link */
a {
  color: #4f46e5;
  text-decoration: none;
}
a:hover {
  text-decoration: underline;
}
</style>

<div class='auth-shell'>

  <!-- Login Card -->
  <div class='card auth-card'>

    <p class='page-subtitle' style='text-transform:uppercase; letter-spacing:0.08em; margin-bottom:6px;'>
      Secure Portal
    </p>

    <h2 class='page-title'>Login</h2>

    ${error ? `<p class='error'>${error}</p>` : ''}

    <form method='post' action='/auth/login' style='margin-top:14px;'>

      <div class='row'>
        <div>
          <label>Email</label>
          <input name='email' type='email' required />
        </div>

        <div>
          <label>Password</label>
          <input name='password' type='password' required />
        </div>
      </div>

      <div style='margin-top:14px;'>
        <button type='submit'>Login</button>
      </div>

    </form>

    <p class='page-subtitle' style='margin-top:12px;'>
      No account? <a href='/auth/register'>Register</a>
    </p>

  </div>

  <!-- Role Guide -->
  <div class='card auth-card'>

    <h3 style='margin:0;'>Role Guide</h3>

    <p class='page-subtitle'>
      Use your registered credentials. Role is detected automatically after login.
    </p>

    <div class='role-login-grid'>

      <div class='role-login patient'>
        <div class='role-title'>Patient</div>
        <div class='role-desc'>
          Book appointments, upload reports, manage family health records, and view prescriptions.
        </div>
      </div>

      <div class='role-login doctor'>
        <div class='role-title'>Doctor</div>
        <div class='role-desc'>
          Manage slots, join consultations, review patient history, and issue prescriptions.
        </div>
      </div>

      <div class='role-login'>
        <div class='role-title'>Admin</div>
        <div class='role-desc'>
          Full system control and access to all records.
        </div>
      </div>

    </div>

  </div>

</div>

` }) %>
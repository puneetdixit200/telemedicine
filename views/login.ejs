<%- include('partials/layout', { title: 'Login', user, body: `
<div class='card max-w-2xl mx-auto'>
  <p class='text-xs uppercase tracking-wider text-sky-700 font-semibold mb-1'>Welcome Back</p>
  <h2 class='text-3xl font-semibold m-0'>Login</h2>
  ${error ? `<p class='error'>${error}</p>` : ''}
  <form method='post' action='/auth/login' class='mt-4'>
    <div class='row'>
      <div>
        <label>Email</label>
        <input name='email' type='email' required />
      </div>
      <div>
        <label>Password</label>
        <input name='password' type='password' required />
      </div>
    </div>
    <div class='mt-4'>
      <button type='submit'>Login</button>
    </div>
  </form>
  <p class='mt-4 text-slate-600'>No account? <a href='/auth/register'>Register</a></p>
</div>
` }) %>

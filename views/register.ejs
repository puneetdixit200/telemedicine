<%- include('partials/layout', { title: 'Register', user, body: `
<div class='card max-w-4xl mx-auto'>
  <p class='text-xs uppercase tracking-wider text-emerald-700 font-semibold mb-1'>New Account</p>
  <h2 class='text-3xl font-semibold m-0'>Register</h2>
  ${error ? `<p class='error'>${error}</p>` : ''}
  <form method='post' action='/auth/register' class='mt-4'>
    <div class='row'>
      <div>
        <label>Full name</label>
        <input name='fullName' required />
      </div>
      <div>
        <label>Email</label>
        <input name='email' type='email' required />
      </div>
      <div>
        <label>Phone</label>
        <input name='phone' />
      </div>
      <div>
        <label>Password</label>
        <input name='password' type='password' required />
      </div>
      <div>
        <label>Role</label>
        <select name='role' required>
          <option value='patient'>Patient</option>
          <option value='doctor'>Doctor</option>
          <option value='admin'>Admin</option>
        </select>
      </div>
      <div>
        <label>Admin invite code (only if admin)</label>
        <input name='adminInviteCode' />
      </div>
      <div>
        <label>Gender</label>
        <input name='gender' />
      </div>
      <div>
        <label>Date of birth</label>
        <input name='dateOfBirth' type='date' />
      </div>
      <div>
        <label>Address</label>
        <input name='address' />
      </div>
      <div>
        <label>Language preference</label>
        <input name='language' />
      </div>
      <div>
        <label>Time zone</label>
        <input name='timeZone' placeholder='e.g. Asia/Kolkata' />
      </div>
    </div>

    <div class='card !bg-slate-50'>
      <h3 class='text-lg font-semibold m-0 mb-2'>Doctor details (only if role=doctor)</h3>
      <div class='row'>
        <div><label>Specialization</label><input name='specialization' /></div>
        <div><label>Years of experience</label><input name='yearsOfExperience' type='number' min='0' /></div>
        <div><label>Qualifications</label><input name='qualifications' /></div>
        <div><label>Clinic/Hospital name</label><input name='clinicName' /></div>
        <div><label>Consultation languages</label><input name='consultationLanguages' placeholder='English,Hindi' /></div>
      </div>
      <div class='mt-2'><label>Description</label><textarea name='description' rows='2'></textarea></div>
    </div>

    <div class='mt-4'>
      <button type='submit'>Create account</button>
    </div>
  </form>
  <p class='mt-4 text-slate-600'>Already have an account? <a href='/auth/login'>Login</a></p>
</div>
` }) %>

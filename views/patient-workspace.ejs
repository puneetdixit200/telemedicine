<%- include('partials/layout', { title: 'Patient Workspace', user, body: `
<div class='card'>
  <div class='row' style='align-items:center;'>
    <div style='flex:0 0 120px;'>
      <img class='doctor-avatar' src='https://i.pravatar.cc/220?u=${user.id}' alt='Patient' />
    </div>
    <div>
      <h2 style='margin:0;'>Patient Profile</h2>
      <div class='badge'>Personal + Family Workspace</div>
    </div>
  </div>
  ${error ? `<p class='error'>${error}</p>` : ''}
  ${message ? `<p class='success'>${message}</p>` : ''}
  <p style='color:#4b5563;'>This page keeps personal and family records separated under the same login.</p>
</div>

<div class='card'>
  <div class='row'>
    <div>
      <h3 style='margin:0 0 8px;'>Personal Details</h3>
      <p><b>Full Name:</b> ${user.fullName || 'N/A'}</p>
      <p><b>Email:</b> ${user.email || 'N/A'}</p>
      <p><b>Phone:</b> ${user.phone || 'N/A'}</p>
      <p><b>Gender:</b> ${user.gender || 'N/A'}</p>
      <p><b>Address:</b> ${user.address || 'N/A'}</p>
      <p><a href='/users/me'>Edit personal details</a></p>
    </div>
    <div>
      <h3 style='margin:0 0 8px;'>Medical History</h3>
      <p><b>Chronic conditions:</b> ${(user.patientProfile && user.patientProfile.chronicConditions) || 'N/A'}</p>
      <p><b>Basic health info:</b> ${(user.patientProfile && user.patientProfile.basicHealthInfo) || 'N/A'}</p>
      <p><a href='/patients/me'>Edit main profile health data</a></p>
    </div>
  </div>
</div>

<div class='card'>
  <h3 class='text-xl font-semibold m-0 mb-2'>Upload Medical Document</h3>
  <p class='text-slate-600'>Upload records for main user or family member.</p>
  <form id='workspaceUploadForm'>
    <label>File is for</label>
    <select name='uploadFor' required>
      <option value='user'>Main user (${user.fullName})</option>
      ${(user.familyMembers || []).map((m) => `
        <option value='${m.id}'>${m.fullName}${m.relationToPatient ? ` (${m.relationToPatient})` : ''}</option>
      `).join('')}
    </select>
    <input type='file' name='file' required />
    <button type='submit'>Upload Medical Document</button>
    <div id='workspaceUploadStatus'></div>
  </form>
</div>

<div class='card'>
  <h3 class='text-xl font-semibold m-0 mb-2'>Add Family Member</h3>
  <form method='post' action='/patients/family-members' class='row'>
    <div><label>Full name</label><input name='fullName' required /></div>
    <div><label>Relation</label><input name='relationToPatient' placeholder='Son / Mother / Spouse' /></div>
    <div><label>Gender</label><input name='gender' /></div>
    <div><label>Date of birth</label><input type='date' name='dateOfBirth' /></div>
    <div style='flex: 1 1 100%;'><label>Chronic conditions</label><textarea name='chronicConditions' rows='2'></textarea></div>
    <div style='flex: 1 1 100%;'><label>Basic health info</label><textarea name='basicHealthInfo' rows='2'></textarea></div>
    <div style='align-self:end;'><button type='submit'>Save Family Member</button></div>
  </form>
</div>

<div class='card'>
  <h3 class='text-xl font-semibold m-0 mb-2'>Family Members</h3>
  ${user.familyMembers && user.familyMembers.length ? '' : '<p>No family members added yet.</p>'}
  ${(user.familyMembers || []).map(m => `
    <div class='card !bg-white/70'>
      <form method='post' action='/patients/family-members/update' class='row'>
        <input type='hidden' name='familyMemberId' value='${m.id}' />
        <div><label>Full name</label><input name='fullName' value='${m.fullName || ''}' required /></div>
        <div><label>Relation</label><input name='relationToPatient' value='${m.relationToPatient || ''}' /></div>
        <div><label>Gender</label><input name='gender' value='${m.gender || ''}' /></div>
        <div><label>Date of birth</label><input type='date' name='dateOfBirth' value='${m.dateOfBirth ? new Date(m.dateOfBirth).toISOString().slice(0,10) : ''}' /></div>
        <div style='flex: 1 1 100%;'><label>Chronic conditions</label><textarea name='chronicConditions' rows='2'>${m.chronicConditions || ''}</textarea></div>
        <div style='flex: 1 1 100%;'><label>Basic health info</label><textarea name='basicHealthInfo' rows='2'>${m.basicHealthInfo || ''}</textarea></div>
        <div style='align-self:end;'><button type='submit'>Update</button></div>
      </form>
    </div>
  `).join('')}
</div>

<div class='card'>
  <h3 class='text-xl font-semibold m-0 mb-2'>Prescriptions & Completed Consultations</h3>
  ${completedAppointments.length === 0 ? '<p>No completed consultations yet.</p>' : ''}
  <div class='timeline'>
    ${completedAppointments.map(a => `
      <div class='timeline-item'>
        <div><b>${new Date(a.startAt).toISOString().replace('T',' ').slice(0,16)} UTC</b></div>
        <div><b>Doctor:</b> ${a.doctor.fullName}</div>
        <div><b>For:</b> ${a.familyMember ? a.familyMember.fullName : user.fullName}</div>
        <div><b>Diagnosis:</b> ${a.prescription ? a.prescription.diagnosis : 'No prescription'}</div>
        ${a.prescription ? `<div><a href='/prescriptions/${a.id}/pdf'>Download PDF</a></div>` : ''}
      </div>
    `).join('')}
  </div>
</div>
<script src='/public/js/patient-workspace-upload.js'></script>
` }) %>

<%- include('partials/layout', { title: 'Appointment', user, body: `
<div class='card'>
  <h2 class='text-3xl font-semibold m-0 mb-2'>Appointment</h2>
  ${error ? `<p class='error'>${error}</p>` : ''}
  ${message ? `<p class='success'>${message}</p>` : ''}
  ${appointment.status !== 'booked' ? `<p class='badge'>Closed appointment: details are view-only for doctor and patient.</p>` : ''}

  <p><b>Time:</b> ${new Date(appointment.startAt).toISOString().replace('T',' ').slice(0,16)} UTC</p>
  <p><b>Status:</b> <span class='badge'>${appointment.status}</span> <span class='badge'>${appointment.mode}</span></p>
  <p><b>Doctor:</b> ${appointment.doctor.fullName}</p>
  <p><b>Patient:</b> ${appointment.familyMember ? `${appointment.familyMember.fullName} (family)` : appointment.patient.fullName}</p>
  <p>
    <b>Doctor online:</b> <span id='doctorOnlineBadge' class='badge'>${presence && presence.doctorOnline ? 'online' : 'offline'}</span>
    <b>Patient online:</b> <span id='patientOnlineBadge' class='badge'>${presence && presence.patientOnline ? 'online' : 'offline'}</span>
  </p>

  <div class='row' style='align-items:center;'>
    <div>
      ${presence && presence.canStartCall
        ? `<a id='joinCallLink' href='/calls/${appointment.id}'>Join Call (Video/Audio/Text)</a>`
        : `<span id='joinCallLink' class='badge'>Call locked: both users must be online</span>`}
    </div>
    <div>
      <a href='/prescriptions/${appointment.id}'>Prescription</a>
    </div>
    <div>
      ${(appointment.status !== 'completed' && appointment.status !== 'cancelled') && ((user.role === 'doctor' && user.id === appointment.doctorId) || user.role === 'admin') ? `
        <form method='post' action='/appointments/${appointment.id}/end' style='margin:0;'>
          <button type='submit'>Close appointment</button>
        </form>
      ` : ''}
    </div>
    <div>
      ${appointment.status === 'booked' ? `
        <form method='post' action='/appointments/${appointment.id}/cancel' style='margin:0;'>
          <button class='secondary' type='submit'>Cancel appointment</button>
        </form>
      ` : ''}
    </div>
  </div>
</div>

<div class='card'>
  <h3 class='text-xl font-semibold m-0 mb-2'>Medical History</h3>
  <p><b>For:</b> ${history.currentPatientProfile.name}${history.currentPatientProfile.relationToPatient ? ` (${history.currentPatientProfile.relationToPatient})` : ''}</p>
  <p><b>Chronic conditions:</b> ${history.currentPatientProfile.chronicConditions || 'N/A'}</p>
  <p><b>Basic health info:</b> ${history.currentPatientProfile.basicHealthInfo || 'N/A'}</p>

  <h4>Previous completed consultations</h4>
  ${history.historyAppointments.length === 0 ? '<p>No previous completed consultations found.</p>' : ''}
  ${history.historyAppointments.map(a => `
    <div class='card !bg-white/70'>
      <div><b>${new Date(a.startAt).toISOString().replace('T',' ').slice(0,16)} UTC</b> with ${a.doctor.fullName}</div>
      <div>${a.prescription ? `Diagnosis: ${a.prescription.diagnosis}` : 'No prescription'}</div>
    </div>
  `).join('')}
</div>

<div class='card'>
  <h3 class='text-xl font-semibold m-0 mb-2'>Pre-consultation</h3>
  ${user.role === 'patient' && appointment.status === 'booked' ? `
    <form method='post' action='/appointments/${appointment.id}/prep'>
      <div style='margin-top:10px;'>
        <label>Problem description</label>
        <textarea name='problemDescription' rows='3'>${appointment.problemDescription || ''}</textarea>
      </div>
      <div style='margin-top:10px;'>
        <label>Current / past medications</label>
        <textarea name='medicationsText' rows='3'>${appointment.medicationsText || ''}</textarea>
      </div>
      <div style='margin-top:12px;'>
        <button type='submit'>Save</button>
      </div>
    </form>
  ` : `
    <p><b>Problem:</b></p>
    <pre>${appointment.problemDescription || ''}</pre>
    <p><b>Medications:</b></p>
    <pre>${appointment.medicationsText || ''}</pre>
  `}
</div>

<div class='card'>
  <h3 class='text-xl font-semibold m-0 mb-2'>Documents</h3>
  ${user.role === 'patient' ? `<p class='badge'>Upload is available only when appointment status is booked.</p>` : ''}
  ${user.role === 'patient' && appointment.status === 'booked' ? `
    <form id='uploadForm'>
      <input type='hidden' name='appointmentId' value='${appointment.id}' />
      <label>File is for</label>
      <select name='uploadFor' required>
        <option value='user' ${appointment.familyMember ? '' : 'selected'}>Main user (${appointment.patient.fullName})</option>
        ${(familyMembers || []).map((m) => `
          <option value='${m.id}' ${appointment.familyMember && appointment.familyMember.id === m.id ? 'selected' : ''}>
            ${m.fullName}${m.relationToPatient ? ` (${m.relationToPatient})` : ''}
          </option>
        `).join('')}
      </select>
      <input name='file' type='file' required />
      <button type='submit'>Upload Medical Document</button>
      <div id='uploadStatus'></div>
    </form>
  ` : user.role === 'patient' ? '<p class="error">Upload disabled because this appointment is closed/cancelled. Book a new appointment to upload new files.</p>' : ''}

  <div id='documentsList'>
    ${appointment.documents && appointment.documents.length ? appointment.documents.map(d => `
      <div class='row' style='align-items:center;'>
        <div>${d.fileName}</div>
        <div><span class='badge'>${Math.round(d.sizeBytes/1024)} KB</span></div>
        <div><a href='/documents/${d.id}/download'>Download</a></div>
      </div>
    `).join('') : '<p>No documents yet.</p>'}
  </div>
</div>

<div class='card'>
  <h3 class='text-xl font-semibold m-0 mb-2'>Workspace Uploads (Before Appointment)</h3>
  <p class='text-slate-600'>These are files uploaded from Patient Workspace for this patient context.</p>
  <div id='workspaceDocumentsList'>
    ${(workspaceDocuments || []).length ? (workspaceDocuments || []).map(d => `
      <div class='row' style='align-items:center;'>
        <div>${d.fileName}</div>
        <div><span class='badge'>${Math.round(d.sizeBytes/1024)} KB</span></div>
        <div><a href='/documents/${d.id}/download'>Download</a></div>
      </div>
    `).join('') : '<p>No workspace uploads found.</p>'}
  </div>
</div>

<div
  id='appointmentRuntime'
  data-appointment-id='${appointment.id}'
  data-is-doctor='${user.role === 'doctor' ? 'true' : 'false'}'
  data-call-href='/calls/${appointment.id}'
></div>
<script src='/public/js/appointment.js'></script>
` }) %>

<%- include('partials/layout', { title: 'Appointment', user, body: `

<style>
.card {
  background: #ffffff;
  border-radius: 16px;
  padding: 20px;
  margin-bottom: 20px;
  box-shadow: 0 6px 20px rgba(0,0,0,0.06);
  border: 1px solid #f1f1f1;
}

.badge {
  display: inline-block;
  padding: 4px 10px;
  border-radius: 999px;
  background: #eef2ff;
  color: #3730a3;
  font-size: 12px;
  margin-right: 6px;
}

.btn-primary {
  background: #4f46e5;
  color: white;
  padding: 8px 14px;
  border-radius: 8px;
  text-decoration: none;
  transition: 0.2s;
}
.btn-primary:hover {
  background: #4338ca;
}

button {
  background: #ef4444;
  color: white;
  padding: 8px 14px;
  border-radius: 8px;
  border: none;
  cursor: pointer;
}
button.secondary {
  background: #6b7280;
}
button:hover {
  opacity: 0.9;
}

.row {
  display: flex;
  gap: 12px;
  flex-wrap: wrap;
}

.timeline-item {
  border-left: 3px solid #4f46e5;
  padding-left: 10px;
  margin-bottom: 10px;
}

textarea, select, input[type="file"] {
  width: 100%;
  padding: 8px;
  border-radius: 8px;
  border: 1px solid #ddd;
}

pre {
  background: #f9fafb;
  padding: 10px;
  border-radius: 8px;
}
</style>

<div class='card'>
  <h2 style='margin:0 0 10px;'>Appointment Details</h2>

  ${error ? `<p class='error' style="color:#dc2626;">${error}</p>` : ''}
  ${message ? `<p class='success' style="color:#16a34a;">${message}</p>` : ''}

  ${appointment.status !== 'booked' ? `<p class='badge'>Closed appointment</p>` : ''}

  <p><b>Time:</b> ${new Date(appointment.startAt).toISOString().replace('T',' ').slice(0,16)} UTC</p>
  <p><b>Status:</b> <span class='badge'>${appointment.status}</span> <span class='badge'>${appointment.mode}</span></p>
  <p><b>Doctor:</b> ${appointment.doctor.fullName}</p>
  <p><b>Patient:</b> ${appointment.familyMember ? `${appointment.familyMember.fullName} (family)` : appointment.patient.fullName}</p>
  <p>
    <b>Triage:</b>
    <span class='badge'>${triage ? triage.label : 'Not assessed'}</span>
    ${reminder && reminder.dueSoon ? `<span class='badge'>${reminder.label}</span>` : ''}
  </p>

  <p>
    <b>Doctor:</b> <span id='doctorOnlineBadge' class='badge'>${presence && presence.doctorOnline ? 'online' : 'offline'}</span>
    <b>Patient:</b> <span id='patientOnlineBadge' class='badge'>${presence && presence.patientOnline ? 'online' : 'offline'}</span>
  </p>

  <div class='row' style='margin-top:10px;'>
    <div>
      ${presence && presence.canStartCall
        ? `<a id='joinCallLink' class='btn-primary' href='/calls/${appointment.id}'>Join Call</a>`
        : `<span id='joinCallLink' class='badge'>Call locked</span>`}
    </div>

    <div>
      <a href='/prescriptions/${appointment.id}' class='btn-primary'>Prescription</a>
    </div>

    <div>
      ${(appointment.status !== 'completed' && appointment.status !== 'cancelled') && ((user.role === 'doctor' && user.id === appointment.doctorId) || user.role === 'admin') ? `
        <form method='post' action='/appointments/${appointment.id}/end'>
          <button type='submit'>Close</button>
        </form>
      ` : ''}
    </div>

    <div>
      ${appointment.status === 'booked' ? `
        <form method='post' action='/appointments/${appointment.id}/cancel'>
          <button class='secondary' type='submit'>Cancel</button>
        </form>
      ` : ''}
    </div>
  </div>
</div>

<div class='card'>
  <h3>Medical History</h3>

  <p><b>For:</b> ${history.currentPatientProfile.name}</p>
  <p><b>Chronic:</b> ${history.currentPatientProfile.chronicConditions || 'N/A'}</p>
  <p><b>Health:</b> ${history.currentPatientProfile.basicHealthInfo || 'N/A'}</p>

  <h4 style='margin-top:10px;'>Previous Consultations</h4>

  ${history.historyAppointments.length === 0 ? '<p>No history found</p>' : ''}

  <div class='timeline'>
    ${history.historyAppointments.map(a => `
      <div class='timeline-item'>
        <div><b>${new Date(a.startAt).toISOString().replace('T',' ').slice(0,16)}</b></div>
        <div>${a.prescription ? a.prescription.diagnosis : 'No prescription'}</div>
      </div>
    `).join('')}
  </div>
</div>

<div class='card'>
  <h3>Pre-consultation</h3>

  ${user.role === 'patient' && appointment.status === 'booked' ? `
    <form id='preconsultForm' method='post' action='/appointments/${appointment.id}/prep'>
      <label>Symptoms and concerns</label>
      <textarea name='problemDescription' placeholder='Describe your current symptoms and concerns...'>${appointment.problemDescription || ''}</textarea>
      <label>Current medicines</label>
      <textarea name='medicationsText' placeholder='List medicines you currently take...'>${appointment.medicationsText || ''}</textarea>
      <p id='preconsultSyncStatus' class='page-subtitle'>Offline-safe: edits are saved locally and synced when internet returns.</p>
      <button type='submit' style='margin-top:10px;'>Save</button>
    </form>
  ` : `
    <pre>${appointment.problemDescription || ''}</pre>
    <pre>${appointment.medicationsText || ''}</pre>
  `}
</div>

<div class='card'>
  <h3>Documents</h3>

  ${user.role === 'patient' && appointment.status === 'booked' ? `
    <form id='uploadForm'>
      <input type='hidden' name='appointmentId' value='${appointment.id}' />
      <select name='uploadFor'>
        <option value='user' ${appointment.familyMemberId ? '' : 'selected'}>${appointment.patient.fullName}</option>
        ${familyMembers.map((m) => `<option value='${m.id}' ${appointment.familyMemberId === m.id ? 'selected' : ''}>${m.fullName}</option>`).join('')}
      </select>
      <input name='file' type='file' required />
      <button type='submit'>Upload</button>
      <p id='uploadStatus' class='page-subtitle'></p>
    </form>
  ` : ''}

  <div>
    ${appointment.documents?.length ? appointment.documents.map(d => `
      <div class='row'>
        <div>${d.fileName}</div>
        <div class='badge'>${Math.round(d.sizeBytes/1024)} KB</div>
        <div><a href='/documents/${d.id}/download'>Download</a></div>
      </div>
    `).join('') : '<p>No documents</p>'}
  </div>
</div>

<div id='appointmentRuntime'
  data-appointment-id='${appointment.id}'
  data-is-doctor='${user.role === 'doctor' ? 'true' : 'false'}'
  data-call-href='/calls/${appointment.id}'></div>

<script src='/public/js/appointment.js'></script>

` }) %>
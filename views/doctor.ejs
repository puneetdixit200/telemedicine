<%- include('partials/layout', { title: 'Doctor', user, body: `
<div class='card'>
  <h2 class='text-3xl font-semibold m-0'>${doctor.fullName}</h2>
  <div class='badge'>${(doctor.doctorProfile && doctor.doctorProfile.specialization) || 'Doctor'}</div>
  <div class='badge'>${doctorOnline ? 'online' : 'offline'}</div>
  <p class='text-slate-600'>${(doctor.doctorProfile && doctor.doctorProfile.description) || ''}</p>
</div>

<div class='card'>
  <h3 class='text-xl font-semibold m-0 mb-2'>Available slots (15 minutes)</h3>
  ${user.role !== 'patient' ? '<p class="error">Only patients can book.</p>' : ''}
  ${slots.length === 0 ? '<p>No upcoming slots.</p>' : ''}
  ${slots.map(s => `
    <div class='row card !m-0 mb-3 !bg-white/70' style='align-items:center;'>
      <div>${new Date(s.startAt).toISOString().replace('T',' ').slice(0,16)} UTC</div>
      <div><span class='badge'>${s.status}</span></div>
      <div>
        ${user.role === 'patient' && s.status === 'available' ? `
          <form method='post' action='/appointments/book' style='margin:0;'>
            <input type='hidden' name='slotId' value='${s.id}' />
            <label>Mode</label>
            <select name='mode'>
              <option value='video'>Video</option>
              <option value='audio'>Audio</option>
              <option value='text'>Text</option>
            </select>
            <label style='margin-top:6px;'>For</label>
            <select name='familyMemberId'>
              <option value=''>Self (${user.fullName})</option>
              ${(familyMembers || []).map(m => `<option value='${m.id}'>${m.fullName}${m.relationToPatient ? ` (${m.relationToPatient})` : ''}</option>`).join('')}
            </select>
            <button type='submit' class='mt-2'>Book</button>
          </form>
        ` : ''}
      </div>
    </div>
  `).join('')}
</div>
` }) %>

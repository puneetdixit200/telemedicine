<%- include('partials/layout', { title: 'Doctor', user, body: `

<style>
.card {
  background: #fff;
  border-radius: 16px;
  padding: 20px;
  margin-bottom: 20px;
  box-shadow: 0 6px 20px rgba(0,0,0,0.06);
  border: 1px solid #f1f1f1;
}

/* Stepper */
.stepper {
  display: flex;
  gap: 10px;
  margin-bottom: 16px;
}
.step {
  flex: 1;
  text-align: center;
  padding: 8px;
  border-radius: 999px;
  background: #f3f4f6;
  font-size: 13px;
}
.step.active {
  background: #4f46e5;
  color: #fff;
}

/* Doctor Header */
.doctor-head {
  display: flex;
  gap: 16px;
  align-items: center;
}
.doctor-avatar {
  width: 70px;
  height: 70px;
  border-radius: 50%;
  border: 2px solid #eef2ff;
}
.doctor-name {
  margin: 0;
  font-size: 1.4rem;
}
.doctor-speciality {
  color: #6b7280;
  font-size: 0.9rem;
}

/* Badge */
.badge {
  display: inline-block;
  padding: 4px 10px;
  border-radius: 999px;
  font-size: 12px;
  background: #eef2ff;
  color: #3730a3;
}

/* Layout */
.booking-layout {
  display: flex;
  gap: 20px;
  flex-wrap: wrap;
}
.calendar-panel {
  flex: 1 1 320px;
}
.slots-panel {
  flex: 1 1 320px;
}

/* Calendar */
.calendar-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 10px;
}
.calendar-title {
  margin: 0;
}
.calendar-nav button {
  background: #e5e7eb;
  border: none;
  padding: 6px 10px;
  border-radius: 6px;
  cursor: pointer;
}
.calendar-nav button:hover {
  background: #d1d5db;
}

.calendar-weekdays {
  display: grid;
  grid-template-columns: repeat(7, 1fr);
  font-size: 12px;
  color: #6b7280;
  margin-bottom: 6px;
}

.calendar-grid {
  display: grid;
  grid-template-columns: repeat(7, 1fr);
  gap: 6px;
}

/* Slots */
.slots-list {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
}

.slot-btn {
  padding: 6px 10px;
  border-radius: 8px;
  border: 1px solid #ddd;
  cursor: pointer;
  font-size: 13px;
}
.slot-btn:hover {
  background: #eef2ff;
}

/* Form */
select, input {
  width: 100%;
  padding: 8px;
  border-radius: 8px;
  border: 1px solid #ddd;
  margin-top: 4px;
}

label {
  font-size: 12px;
  color: #6b7280;
  display: block;
}

button[type="submit"] {
  background: #4f46e5;
  color: white;
  padding: 10px;
  border-radius: 8px;
  border: none;
  cursor: pointer;
}
button[type="submit"]:hover {
  background: #4338ca;
}
</style>

<!-- Doctor Info -->
<div class='card'>
  <div class='stepper'>
    <div class='step'>1. Select Specialist</div>
    <div class='step active'>2. Choose Time</div>
    <div class='step'>3. Confirm</div>
  </div>

  <div class='doctor-head'>
    <img class='doctor-avatar' src='/public/img/doctor-generic.svg' alt='Doctor' />
    <div>
      <h2 class='doctor-name'>Dr. ${doctor.fullName}</h2>
      <div class='doctor-speciality'>${(doctor.doctorProfile && doctor.doctorProfile.specialization) || 'Doctor'}</div>

      <div>
        <span class='badge'>
          ${doctorOnline ? '🟢 Online' : '🔴 Offline'}
        </span>
      </div>

      <p style='margin-top:6px; color:#4b5563;'>
        ${(doctor.doctorProfile && doctor.doctorProfile.description) || ''}
      </p>
    </div>
  </div>
</div>

<!-- Booking Section -->
<div class='card'>
  <div class='booking-layout'>

    <!-- Calendar -->
    <div class='calendar-panel'>
      <div class='calendar-header'>
        <h3 id='calendarTitle' class='calendar-title'>Calendar</h3>
        <div class='calendar-nav'>
          <button id='calendarPrev' type='button'>&lt;</button>
          <button id='calendarNext' type='button'>&gt;</button>
        </div>
      </div>

      <div class='calendar-weekdays'>
        <span>Sun</span><span>Mon</span><span>Tue</span>
        <span>Wed</span><span>Thu</span><span>Fri</span><span>Sat</span>
      </div>

      <div id='calendarGrid' class='calendar-grid'></div>
    </div>

    <!-- Slots -->
    <div class='slots-panel'>
      <h3 id='slotsTitle' style='margin-bottom:10px;'>Available Time Slots</h3>

      ${user.role !== 'patient' ? '<p style="color:#dc2626;">Only patients can book.</p>' : ''}

      <div id='slotsList' class='slots-list'></div>

      ${user.role === 'patient' ? `
        <form method='post' action='/appointments/book' class='card' style='margin-top:12px; padding:16px;'>
          <input id='selectedSlotId' type='hidden' name='slotId' value='' />

          <label>Mode</label>
          <select name='mode'>
            <option value='video'>Video</option>
            <option value='audio'>Audio</option>
            <option value='text'>Text</option>
          </select>

          <label style='margin-top:10px;'>For</label>
          <select name='familyMemberId'>
            <option value=''>Self (${user.fullName})</option>
            ${(familyMembers || []).map(m => `<option value='${m.id}'>${m.fullName}${m.relationToPatient ? ` (${m.relationToPatient})` : ''}</option>`).join('')}
          </select>

          <button type='submit' style='margin-top:12px;'>Book Appointment</button>
        </form>
      ` : '<p style="color:#dc2626;">Booking available only for patients.</p>'}

      <div id='doctorBookingRuntime' data-slots='${encodeURIComponent(JSON.stringify(slots.map((s) => ({
        id: s.id,
        status: s.status,
        iso: new Date(s.startAt).toISOString(),
        date: new Date(s.startAt).toISOString().slice(0, 10),
        timeLabel: new Date(s.startAt).toISOString().slice(11, 16)
      }))))}'></div>

    </div>
  </div>
</div>

<script src='/public/js/doctor-calendar.js'></script>

` }) %>
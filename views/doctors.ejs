<%- include('partials/layout', { title: 'Doctors', user, body: `
<div class='card'>
  <div class='flex items-center justify-between gap-3 flex-wrap'>
    <h2 class='text-3xl font-semibold m-0'>Find Doctors</h2>
    <span class='badge'>${doctors.length} results</span>
  </div>
  <form method='get' action='/doctors' class='row'>
    <div><label>Specialization</label><input name='specialization' value='${(typeof specialization !== 'undefined' ? specialization : '')}' /></div>
    <div><label>Language</label><input name='language' value='${(typeof language !== 'undefined' ? language : '')}' /></div>
    <div>
      <label>Online</label>
      <select name='online'>
        <option value='all' ${(online || 'all') === 'all' ? 'selected' : ''}>All</option>
        <option value='online' ${(online || 'all') === 'online' ? 'selected' : ''}>Online only</option>
        <option value='offline' ${(online || 'all') === 'offline' ? 'selected' : ''}>Offline only</option>
      </select>
    </div>
    <div style='align-self:end;'><button type='submit'>Filter</button></div>
  </form>
</div>

${doctors.map(d => `
  <div class='card'>
    <div class='row'>
      <div>
        <h3 class='m-0 text-xl font-semibold'>${d.fullName}</h3>
        <div class='badge'>${(d.doctorProfile && d.doctorProfile.specialization) || 'Doctor'}</div>
        <div class='badge'>${d.online ? 'online' : 'offline'}</div>
        <p class='text-slate-600'>${(d.doctorProfile && d.doctorProfile.description) || ''}</p>
      </div>
      <div style='align-self:center;'>
        <a class='inline-flex items-center rounded-lg border border-sky-300 px-3 py-2 text-sky-700 hover:bg-sky-50' href='/doctors/${d.id}'>View profile & slots</a>
      </div>
    </div>
  </div>
`).join('')}
` }) %>

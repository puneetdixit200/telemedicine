<%- include('partials/layout', { title: 'Doctors', user, body: `

<style>
.card {
  background:#fff;
  border-radius:16px;
  padding:20px;
  margin-bottom:20px;
  box-shadow:0 6px 20px rgba(0,0,0,0.06);
  border:1px solid #f1f1f1;
}

.row {
  display:flex;
  gap:14px;
  flex-wrap:wrap;
}

label {
  font-size:12px;
  color:#6b7280;
  display:block;
  margin-bottom:4px;
}

input, select {
  width:100%;
  padding:8px;
  border-radius:8px;
  border:1px solid #ddd;
}

button {
  background:#4f46e5;
  color:#fff;
  padding:10px;
  border-radius:8px;
  border:none;
  cursor:pointer;
}
button:hover {
  background:#4338ca;
}

.btn-primary {
  display:block;
  text-align:center;
  background:#4f46e5;
  color:white;
  padding:10px;
  border-radius:8px;
  text-decoration:none;
}
.btn-primary:hover {
  background:#4338ca;
}

.badge {
  padding:4px 10px;
  border-radius:999px;
  background:#eef2ff;
  color:#3730a3;
  font-size:12px;
}

/* GRID */
.doctor-grid {
  display:grid;
  grid-template-columns: repeat(auto-fill, minmax(280px,1fr));
  gap:16px;
}

.doctor-card {
  background:#fff;
  border-radius:16px;
  padding:16px;
  border:1px solid #eee;
  box-shadow:0 4px 14px rgba(0,0,0,0.04);
  transition:0.2s;
}
.doctor-card:hover {
  transform: translateY(-2px);
}

/* HEADER */
.doctor-head {
  display:flex;
  gap:12px;
}

.doctor-avatar {
  width:56px;
  height:56px;
  border-radius:50%;
}

.doctor-name {
  font-weight:600;
  font-size:1.05rem;
}

.doctor-speciality {
  font-size:0.9rem;
  color:#6b7280;
}

.status-online {
  color:#166534;
  font-weight:500;
}

.status-offline {
  color:#b91c1c;
  font-weight:500;
}
</style>

<div class='card'>
  <div class='row' style='align-items:end;'>

    <div style='flex:1 1 640px;'>
      <label>Search doctors</label>
      <input 
        name='specialization' 
        form='doctorsFilterForm'
        placeholder='Search doctors by name, specialty, or location'
        value='${typeof specialization !== 'undefined' ? specialization : ''}'
      />
    </div>

    <div style='flex:1 1 220px;'>
      <label>Language</label>
      <input 
        name='language' 
        form='doctorsFilterForm'
        value='${typeof language !== 'undefined' ? language : ''}'
      />
    </div>

    <div style='flex:1 1 180px;'>
      <label>Availability</label>
      <select name='online' form='doctorsFilterForm'>
        <option value='all' ${(online || 'all') === 'all' ? 'selected' : ''}>All</option>
        <option value='online' ${(online || 'all') === 'online' ? 'selected' : ''}>Online</option>
        <option value='offline' ${(online || 'all') === 'offline' ? 'selected' : ''}>Offline</option>
      </select>
    </div>

    <div style='flex:0 0 170px;'>
      <button form='doctorsFilterForm' type='submit' style='width:100%;'>
        Search
      </button>
    </div>

  </div>

  <form id='doctorsFilterForm' method='get' action='/doctors'></form>
</div>

<div class='doctor-grid'>

  ${doctors.map(d => `
    <div class='doctor-card'>

      <div class='doctor-head'>
        <img class='doctor-avatar' src='/public/img/doctor-generic.svg' />

        <div>
          <div class='doctor-name'>Dr. ${d.fullName}</div>

          <div class='doctor-speciality'>
            ${(d.doctorProfile && d.doctorProfile.specialization) || 'General Physician'}
          </div>

          <div>
            Availability 
            <span class='${d.online ? 'status-online' : 'status-offline'}'>
              ${d.online ? 'online' : 'offline'}
            </span>
          </div>

          <div style='margin-top:6px; display:flex; gap:6px; flex-wrap:wrap;'>
            <span class='badge'>English</span>
            <span class='badge'>Hindi</span>
            <span class='badge'>Video</span>
          </div>
        </div>
      </div>

      <div style='margin-top:12px;'>
        <a href='/doctors/${d.id}' class='btn-primary'>
          Book Appointment
        </a>
      </div>

    </div>
  `).join('')}

</div>

` }) %>
<%- include('partials/layout', { title: 'Prescription', user, body: `
<div class='card'>
  <h2 class='text-3xl font-semibold m-0 mb-2'>Prescription</h2>
  ${error ? `<p class='error'>${error}</p>` : ''}
  ${message ? `<p class='success'>${message}</p>` : ''}

  <p><b>Appointment:</b> ${appointment.id}</p>
  <p><b>Doctor:</b> ${appointment.doctor.fullName} | <b>Patient:</b> ${appointment.familyMember ? `${appointment.familyMember.fullName} (family)` : appointment.patient.fullName}</p>
  <div class='row' style='align-items:center;'>
    <div style='flex:0 0 auto;'><button id='btnBackNav' class='secondary' type='button'>Back</button></div>
    <div style='flex:0 0 auto;'><button id='btnForwardNav' class='secondary' type='button'>Forward</button></div>
  </div>

  ${appointment.prescription ? `
    <div class='card !bg-white/70'>
      <p><b>Diagnosis:</b> ${appointment.prescription.diagnosis}</p>
      <p><b>Medications:</b></p>
      ${(Array.isArray(appointment.prescription.items) && appointment.prescription.items.length > 0)
        ? `<div class='med-list'>${appointment.prescription.items.map((i, idx) => `
            <div class='med-item'>
              <div class='med-title'>${idx + 1}. ${i.name || 'Medication'}</div>
              <div class='med-meta'>
                <span class='badge'>Dosage: ${i.dosage || 'N/A'}</span>
                <span class='badge'>Frequency: ${i.frequency || 'N/A'}</span>
                <span class='badge'>Duration: ${i.duration || 'N/A'}</span>
              </div>
            </div>
          `).join('')}</div>`
        : '<p>No medications listed.</p>'}
      <p><b>Instructions:</b></p>
      <p>${appointment.prescription.instructions || 'No instructions provided.'}</p>
      <p><a href='/prescriptions/${appointment.id}/pdf'>Download PDF</a></p>
    </div>
  ` : '<p>No prescription yet.</p>'}

  ${user.role === 'doctor' && user.id === appointment.doctorId ? `
    <div class='card'>
      <h3 class='text-xl font-semibold m-0 mb-2'>${appointment.prescription ? 'Edit' : 'Create'} prescription</h3>
      <form method='post' action='/prescriptions/${appointment.id}'>
        <div>
          <label>Diagnosis</label>
          <input name='diagnosis' value='${appointment.prescription ? appointment.prescription.diagnosis : ''}' required />
        </div>
        <div class='mt-3'>
          <label>Medications</label>
          <div id='medicationRows'>
            ${(appointment.prescription && Array.isArray(appointment.prescription.items) && appointment.prescription.items.length
              ? appointment.prescription.items
              : [{ name: '', dosage: '', frequency: '', duration: '' }]
            ).map((i) => `
              <div class='med-form-row'>
                <input name='medicationName' placeholder='Medicine name' value='${i.name || ''}' required />
                <input name='dosage' placeholder='Dosage' value='${i.dosage || ''}' />
                <input name='frequency' placeholder='Frequency' value='${i.frequency || ''}' />
                <input name='duration' placeholder='Duration' value='${i.duration || ''}' />
              </div>
            `).join('')}
          </div>
          <button id='btnAddMedication' class='secondary mt-2' type='button'>Add medicine</button>
        </div>
        <div class='mt-3'>
          <label>Instructions</label>
          <textarea name='instructions' rows='2'>${appointment.prescription ? (appointment.prescription.instructions || '') : ''}</textarea>
        </div>
        <div class='mt-3'>
          <label>Follow-up date</label>
          <input name='followUpAt' type='date' value='${appointment.prescription && appointment.prescription.followUpAt ? new Date(appointment.prescription.followUpAt).toISOString().slice(0,10) : ''}' />
        </div>
        <div class='mt-3'>
          <label>Notes</label>
          <textarea name='notes' rows='2'>${appointment.prescription ? (appointment.prescription.notes || '') : ''}</textarea>
        </div>
        <div class='mt-4'>
          <button type='submit'>Save prescription</button>
        </div>
      </form>
    </div>
  ` : ''}
</div>
<script src='/public/js/prescription.js'></script>
` }) %>

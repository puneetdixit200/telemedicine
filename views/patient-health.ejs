<%- include('partials/layout', { title: 'My Health', user, body: `
<div class='card'>
  <h2 class='text-3xl font-semibold m-0'>My Health</h2>
  ${error ? `<p class='error'>${error}</p>` : ''}
  ${message ? `<p class='success'>${message}</p>` : ''}

  <form method='post' action='/patients/me'>
    <div class='mt-3'>
      <label>Chronic conditions</label>
      <textarea name='chronicConditions' rows='2'>${(user.patientProfile && user.patientProfile.chronicConditions) || ''}</textarea>
    </div>
    <div class='mt-3'>
      <label>Basic health info</label>
      <textarea name='basicHealthInfo' rows='2'>${(user.patientProfile && user.patientProfile.basicHealthInfo) || ''}</textarea>
    </div>
    <div class='mt-4'>
      <button type='submit'>Save</button>
    </div>
  </form>
</div>
` }) %>

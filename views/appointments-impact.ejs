<%- include('partials/layout', { title: 'Impact Dashboard', user, body: `
<div class='card'>
  <div class='hero-header'>
    <div>
      <h2 class='page-title'>Impact Dashboard</h2>
      <p class='page-subtitle'>Outcome and access indicators from your consultations.</p>
    </div>
    <a class='btn-secondary' href='/appointments'>Back to appointments</a>
  </div>
</div>

<div class='split-grid'>
  <div class='card'>
    <p class='page-subtitle'>Total consultations</p>
    <h3 style='margin:4px 0 0; font-size:2rem;'>${metrics.total}</h3>
  </div>
  <div class='card'>
    <p class='page-subtitle'>Completion rate</p>
    <h3 style='margin:4px 0 0; font-size:2rem;'>${metrics.completionRate}%</h3>
  </div>
  <div class='card'>
    <p class='page-subtitle'>Average consult duration</p>
    <h3 style='margin:4px 0 0; font-size:2rem;'>${metrics.avgConsultMins} min</h3>
  </div>
  <div class='card'>
    <p class='page-subtitle'>Urgent triage cases</p>
    <h3 style='margin:4px 0 0; font-size:2rem;'>${metrics.urgentCount}</h3>
  </div>
</div>

<div class='split-grid'>
  <div class='card'>
    <h3 style='margin-top:0;'>Appointments by status</h3>
    <p><span class='badge'>Booked</span> ${metrics.statusCounts.booked || 0}</p>
    <p><span class='badge'>Completed</span> ${metrics.statusCounts.completed || 0}</p>
    <p><span class='badge'>Cancelled</span> ${metrics.statusCounts.cancelled || 0}</p>
    <p><span class='badge'>No show</span> ${metrics.statusCounts.no_show || 0}</p>
  </div>

  <div class='card'>
    <h3 style='margin-top:0;'>Follow-up readiness</h3>
    <p><span class='badge'>Reminder due in 24h</span> ${metrics.reminderDueCount}</p>
    <p><span class='badge'>Follow-ups in next 14d</span> ${metrics.followUpCount}</p>
    <p class='page-subtitle'>Use this view to prioritize outreach and reduce missed care.</p>
  </div>
</div>
` }) %>

<%- include('partials/layout', { title: 'My Slots', user, body: `

<style>
.card {
  background: #fff;
  border-radius: 16px;
  padding: 20px;
  margin-bottom: 20px;
  box-shadow: 0 6px 20px rgba(0,0,0,0.06);
  border: 1px solid #f1f1f1;
}

.row {
  display: flex;
  gap: 14px;
  flex-wrap: wrap;
}

.badge {
  padding: 4px 10px;
  border-radius: 999px;
  background: #eef2ff;
  color: #3730a3;
  font-size: 12px;
}

button {
  background: #4f46e5;
  color: #fff;
  padding: 8px 14px;
  border-radius: 8px;
  border: none;
  cursor: pointer;
  transition: 0.2s;
}
button:hover {
  background: #4338ca;
}
button.secondary {
  background: #6b7280;
}
button.secondary:hover {
  background: #4b5563;
}

input, select {
  padding: 8px;
  border-radius: 8px;
  border: 1px solid #ddd;
  min-width: 140px;
}

label {
  font-size: 12px;
  color: #6b7280;
  display: block;
  margin-bottom: 4px;
}

.slot-item {
  padding: 12px;
  border-radius: 10px;
  border: 1px solid #eee;
  background: #fafafa;
  transition: 0.2s;
}
.slot-item:hover {
  background: #f4f4f5;
}

.status-online {
  background: #dcfce7;
  color: #166534;
}
.status-offline {
  background: #fee2e2;
  color: #991b1b;
}
</style>

<div class='card'>
  <h2 class='text-3xl font-semibold mb-2'>Manage Slots</h2>

  ${error ? `<p style="color:#dc2626;">${error}</p>` : ''}
  ${message ? `<p style="color:#16a34a;">${message}</p>` : ''}

  <!-- Call State -->
  <div class='row' style='align-items:center; margin-bottom: 14px;'>

    <div>
      <b>Call State:</b> 
      <span class='badge ${callState === 'online' ? 'status-online' : 'status-offline'}'>
        ${callState || 'offline'}
      </span>
    </div>

    <div>
      <form method='post' action='/doctors/me/call-state'>
        <input type='hidden' name='state' value='online' />
        <button type='submit'>Go Online</button>
      </form>
    </div>

    <div>
      <form method='post' action='/doctors/me/call-state'>
        <input type='hidden' name='state' value='offline' />
        <button class='secondary' type='submit'>Go Offline</button>
      </form>
    </div>

  </div>

  <!-- Bulk Slot Form -->
  <form method='post' action='/doctors/me/slots/bulk' class='row'>

    <div>
      <label>Date (UTC)</label>
      <input name='date' type='date' required />
    </div>

    <div>
      <label>Start Hour</label>
      <input name='startHourUtc' type='number' min='0' max='23' />
    </div>

    <div>
      <label>End Hour</label>
      <input name='endHourUtc' type='number' min='1' max='24' />
    </div>

    <div>
      <label>Action</label>
      <select name='action'>
        <option value='make_available'>Make Available</option>
        <option value='make_busy'>Make Busy</option>
      </select>
    </div>

    <div style='align-self:end;'>
      <button type='submit'>Apply</button>
    </div>

  </form>
</div>

<div class='card'>
  <h3 class='text-xl font-semibold mb-3'>Upcoming Slots</h3>

  ${slots.length === 0 ? '<p style="color:#6b7280;">No slots found.</p>' : ''}

  ${slots.map(s => `
    <div class='slot-item row' style='align-items:center; margin-bottom:10px;'>

      <div style='flex:1; font-weight:500;'>
        ${new Date(s.startAt).toISOString().replace('T',' ').slice(0,16)} UTC
      </div>

      <div>
        <span class='badge'>
          ${s.status}
        </span>
      </div>

    </div>
  `).join('')}
</div>

` }) %>
<%- include('partials/layout', { title: 'Doctor Analytics', user, body: `
<div class='card'>
  <h2>Doctor Dashboard</h2>
  <p>Last 7 days activity.</p>
</div>

<div class='card'>
  <h3>Status Summary</h3>
  <div class='row'>
    <div><span class='badge'>Booked</span> <b>${statusCounts.booked}</b></div>
    <div><span class='badge'>Completed</span> <b>${statusCounts.completed}</b></div>
    <div><span class='badge'>Cancelled</span> <b>${statusCounts.cancelled}</b></div>
    <div><span class='badge'>No-show</span> <b>${statusCounts.no_show}</b></div>
  </div>
</div>

<div class='card'>
  <h3>Daily Appointments Graph</h3>
  ${dailySeries.map(d => `
    <div style='margin-bottom:10px;'>
      <div class='row' style='align-items:center;'>
        <div style='flex: 0 0 140px;'>${d.day}</div>
        <div style='flex: 1 1 auto; background:#eef2ff; border-radius:999px; height:14px; overflow:hidden;'>
          <div style='height:100%; width:${d.widthPct}%; background:#2563eb;'></div>
        </div>
        <div style='flex: 0 0 40px; text-align:right;'>${d.count}</div>
      </div>
    </div>
  `).join('')}
</div>
` }) %>

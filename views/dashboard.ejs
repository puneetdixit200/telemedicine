<%- include('partials/layout', { title: 'Dashboard', user, body: `
<div class='card'>
  <div class='flex items-start justify-between gap-4 flex-wrap'>
    <div>
      <p class='text-xs uppercase tracking-wider text-sky-700 font-semibold mb-1'>Telemedicine Hub</p>
      <h2 class='text-3xl font-semibold m-0'>Dashboard</h2>
      <p class='text-slate-600 mt-2 mb-0'>Fast access to appointments, profile and workspace tools.</p>
    </div>
    ${user ? `<span class='badge'>${user.role}</span>` : ''}
  </div>
  ${message ? `<p class='success'>${message}</p>` : ''}
  ${!user ? `<p>Please <a href='/auth/login'>login</a>.</p>` : `
    <p class='mt-4'>Welcome, <b>${user.fullName}</b>.</p>
    <div class='grid grid-cols-1 md:grid-cols-2 gap-3 mt-3'>
      <a class='card !m-0 !p-4 hover:!border-sky-300 transition' href='/users/me'>
        <div class='text-sm text-slate-500'>Account</div>
        <div class='text-lg font-semibold text-slate-800'>View / edit profile</div>
      </a>
      ${user.role === 'doctor' ? `<a class='card !m-0 !p-4 hover:!border-sky-300 transition' href='/doctors/me/slots'><div class='text-sm text-slate-500'>Schedule</div><div class='text-lg font-semibold text-slate-800'>Manage your slots</div></a>` : ''}
      ${user.role === 'doctor' ? `<a class='card !m-0 !p-4 hover:!border-sky-300 transition' href='/doctors/me/analytics'><div class='text-sm text-slate-500'>Insights</div><div class='text-lg font-semibold text-slate-800'>Doctor analytics</div></a>` : ''}
      ${user.role === 'patient' ? `<a class='card !m-0 !p-4 hover:!border-sky-300 transition' href='/patients/workspace'><div class='text-sm text-slate-500'>Health Records</div><div class='text-lg font-semibold text-slate-800'>Patient workspace</div></a>` : ''}
    </div>
  `}
</div>
` }) %>

<%- include('partials/layout', { title: 'Dashboard', user, body: `
<div class='card'>
  <div class='hero-header'>
    <div>
      <p class='page-subtitle' style='text-transform:uppercase; letter-spacing:0.08em; margin:0 0 6px;'>Telemedicine Hub</p>
      <h2 class='page-title'>Dashboard</h2>
      <p class='page-subtitle'>Fast access to appointments, profile and workspace tools.</p>
    </div>
    ${user ? `<span class='badge role-chip role-badge role-${user.role}'>${user.role}</span>` : ''}
  </div>
  ${message ? `<p class='success'>${message}</p>` : ''}
  ${!user ? `<p>Please <a href='/auth/login'>login</a>.</p>` : `
    <p style='margin-top:12px;'>Welcome, <b>${user.fullName}</b>.</p>
    <div class='quick-actions'>
      <a class='action-card' href='/users/me'>
        <div class='kicker'>Account</div>
        <div class='headline'>View / edit profile</div>
      </a>
      ${user.role === 'doctor' ? `<a class='action-card' href='/doctors/me/slots'><div class='kicker'>Schedule</div><div class='headline'>Manage your slots</div></a>` : ''}
      ${user.role === 'doctor' ? `<a class='action-card' href='/doctors/me/analytics'><div class='kicker'>Insights</div><div class='headline'>Doctor analytics</div></a>` : ''}
      ${user.role === 'patient' ? `<a class='action-card' href='/patients/workspace'><div class='kicker'>Health Records</div><div class='headline'>Patient workspace</div></a>` : ''}
    </div>
  `}
</div>
` }) %>
